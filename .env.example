# Supabase — copy this file to .env and fill in your project values.
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to the app bundle.
# Find these in your Supabase dashboard: Project Settings → API.

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Client key. Use the new "publishable" key (sb_publishable_...) if your project
# has the new API key system, otherwise the legacy "anon" key. Either name works.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
